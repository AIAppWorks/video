# ============================================
# 本地开发环境配置示例 (.env.local)
# ============================================
# 复制此文件为 .env.local 在本地开发使用
# 注意: .env.local 已在 .gitignore 中，不会被提交到 Git

# 本地数据库（SQLite）
DATABASE_URL="file:./prisma/dev.db"

# 本地开发密钥（可以用任意值）
AUTH_SECRET="dev-secret-key-for-local-testing-only"

# 本地访问 URL
NEXTAUTH_URL="http://localhost:3000"
