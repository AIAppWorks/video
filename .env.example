# ============================================
# 生产环境配置示例 (.env)
# ============================================
# 复制此文件为 .env 并填写实际的值

# 数据库配置
# SQLite 本地文件路径（生产环境建议使用 PostgreSQL）
DATABASE_URL="file:./prisma/prod.db"

# NextAuth 认证密钥
# 用以下命令生成: openssl rand -base64 32
AUTH_SECRET="your-generated-secret-key-here"

# 应用访问 URL（HTTPS 推荐）
NEXTAUTH_URL="https://your-domain.com"
